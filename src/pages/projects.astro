---
import Layout from "../layouts/Layout.astro";

const projects = [
  {
    name: "OhioValues",
    description: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore.",
    tech: ["Vue"],
    url: "https://github.com/Pogo-Bash/OhioValues",
  },
  {
    name: "ochin-pakhi",
    description: "Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip.",
    tech: ["HTML", "CSS", "JavaScript"],
    url: "https://github.com/Pogo-Bash/ochin-pakhi",
  },
  {
    name: "lungseq-analyzer",
    description: "Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat.",
    tech: ["JavaScript"],
    url: "https://github.com/Pogo-Bash/lungseq-analyzer",
  },
  {
    name: "HACwrapper",
    description: "Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit.",
    tech: ["HTML", "JavaScript"],
    url: "https://github.com/Pogo-Bash/HACwrapper",
  },
  {
    name: "webacity-",
    description: "Nemo enim ipsam voluptatem quia voluptas sit aspernatur aut odit aut fugit.",
    tech: ["JavaScript"],
    url: "https://github.com/Pogo-Bash/webacity-",
  },
  {
    name: "webP2P",
    description: "Quis autem vel eum iure reprehenderit qui in ea voluptate velit esse quam nihil molestiae.",
    tech: ["Vue", "WebRTC"],
    url: "https://github.com/Pogo-Bash/webP2P",
  },
];
---

<Layout title="Projects — Swap">
  <h1 class="text-2xl font-bold text-text mb-2">projects</h1>
  <p class="text-subtext0 mb-10">stuff i've built or am building.</p>

  <div class="space-y-6">
    {projects.map((project) => (
      <a
        href={project.url}
        target="_blank"
        rel="noopener"
        class="block p-5 border border-surface0 rounded-lg hover:border-mauve/40 transition-all duration-200 group"
      >
        <div class="flex items-start justify-between mb-2">
          <h2 class="font-bold text-text group-hover:text-mauve transition-colors">
            {project.name}
          </h2>
          <svg class="w-4 h-4 text-overlay0 group-hover:text-mauve transition-colors mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10" />
          </svg>
        </div>
        <p class="text-sm text-subtext0 mb-3">{project.description}</p>
        <div class="flex gap-2">
          {project.tech.map((t) => (
            <span class="text-xs px-2 py-0.5 rounded bg-surface0 text-subtext0">{t}</span>
          ))}
        </div>
      </a>
    ))}
  </div>
</Layout>
