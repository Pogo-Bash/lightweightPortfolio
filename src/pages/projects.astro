---
import Layout from "../layouts/Layout.astro";

const projects = [
  {
    name: "lungseq-analyzer",
    description: "Browser-based lung cancer genomics analysis powered by WebAssembly. Runs locally, your data never leaves your device.",
    tech: ["JavaScript", "Vue", "WebAssembly"],
    url: "https://github.com/Pogo-Bash/lungseq-analyzer",
  },
  {
    name: "webP2P",
    description: "P2P encrypted file sharing that leaves no trace. No server, no accounts, no cloud. Close your tabs and it's gone.",
    tech: ["Vue", "TypeScript", "WebRTC"],
    url: "https://github.com/Pogo-Bash/webP2P",
  },
  {
    name: "webacity-",
    description: "Audacity but in your browser. Multi-track editor with waveform viz and WebAssembly-powered audio effects.",
    tech: ["JavaScript", "Vue", "C++", "WebAssembly"],
    url: "https://github.com/Pogo-Bash/webacity-",
  },
  {
    name: "HACwrapper",
    description: "Encrypted interface for Home Access Center. Check your grades without your school's garbage UI.",
    tech: ["Vue", "TypeScript", "HTML"],
    url: "https://github.com/Pogo-Bash/HACwrapper",
  },
  {
    name: "OhioValues",
    description: "Look up skin values for Roblox Ohio. Vue frontend with a Python scraper backend.",
    tech: ["Vue", "Python", "CSS"],
    url: "https://github.com/Pogo-Bash/OhioValues",
  },
  {
    name: "ochin-pakhi",
    description: "Website for the Bengali music band Ochin Pakhi.",
    tech: ["HTML", "CSS", "JavaScript"],
    url: "https://github.com/Pogo-Bash/ochin-pakhi",
  },
];
---

<Layout title="Projects — Swap">
  <h1 class="text-2xl font-bold text-text mb-2">projects</h1>
  <p class="text-subtext0 mb-10">stuff i've built or am building.</p>

  <div class="space-y-6">
    {projects.map((project) => (
      <a
        href={project.url}
        target="_blank"
        rel="noopener"
        class="block p-5 border border-surface0 rounded-lg hover:border-mauve/40 transition-all duration-200 group"
      >
        <div class="flex items-start justify-between mb-2">
          <h2 class="font-bold text-text group-hover:text-mauve transition-colors">
            {project.name}
          </h2>
          <svg class="w-4 h-4 text-overlay0 group-hover:text-mauve transition-colors mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10" />
          </svg>
        </div>
        <p class="text-sm text-subtext0 mb-3">{project.description}</p>
        <div class="flex gap-2">
          {project.tech.map((t) => (
            <span class="text-xs px-2 py-0.5 rounded bg-surface0 text-subtext0">{t}</span>
          ))}
        </div>
      </a>
    ))}
  </div>
</Layout>
