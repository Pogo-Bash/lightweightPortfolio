---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title="Blog — Swap">
  <h1 class="text-2xl font-bold text-text mb-2">blog</h1>
  <p class="text-subtext0 mb-10">thoughts, notes, and the occasional rant.</p>

  {posts.length === 0 && (
    <p class="text-overlay0">nothing here yet.</p>
  )}

  <div class="space-y-8">
    {posts.map((post) => (
      <a href={`/blog/${post.slug}`} class="block group">
        <time class="text-xs text-overlay0">
          {post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
        </time>
        <h2 class="text-lg font-bold text-text group-hover:text-mauve transition-colors mt-1">
          {post.data.title}
        </h2>
        <p class="text-sm text-subtext0 mt-1">{post.data.description}</p>
      </a>
    ))}
  </div>
</Layout>
